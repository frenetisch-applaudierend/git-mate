#!/usr/bin/env bash
# List unresolved review thread comments for the current PR.
# Saves thread data to /tmp/pr-comments-<pr>.json for use by pr-resolve.
#
# Usage: pr-comments [PR_NUMBER]

set -euo pipefail

PR="${1:-}"
if [[ -z "$PR" ]]; then
    PR="$(gh pr view --json number -q .number 2>/dev/null)" \
        || { echo "error: not on a PR branch (or no open PR found)" >&2; exit 1; }
fi

REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner)"
CACHE="/tmp/pr-comments-${PR}.json"

gh api graphql -f query='
query($repo_owner: String!, $repo_name: String!, $pr: Int!) {
  repository(owner: $repo_owner, name: $repo_name) {
    pullRequest(number: $pr) {
      number
      title
      reviewThreads(first: 100) {
        nodes {
          id
          isResolved
          comments(first: 10) {
            nodes {
              author { login }
              path
              line
              body
            }
          }
        }
      }
    }
  }
}' \
  -f repo_owner="${REPO%%/*}" \
  -f repo_name="${REPO##*/}" \
  -F pr="$PR" > "$CACHE"

TITLE="$(jq -r '.data.repository.pullRequest.title' "$CACHE")"
echo "PR #${PR}: ${TITLE}"
echo

COUNT=0
while IFS= read -r thread; do
    IS_RESOLVED="$(echo "$thread" | jq -r '.isResolved')"
    [[ "$IS_RESOLVED" == "true" ]] && continue

    COUNT=$((COUNT + 1))
    THREAD_ID="$(echo "$thread" | jq -r '.id')"
    FIRST_COMMENT="$(echo "$thread" | jq -r '.comments.nodes[0]')"
    AUTHOR="$(echo "$FIRST_COMMENT" | jq -r '.author.login')"
    PATH_="$(echo "$FIRST_COMMENT" | jq -r '.path')"
    LINE="$(echo "$FIRST_COMMENT" | jq -r '.line')"
    BODY="$(echo "$FIRST_COMMENT" | jq -r '.body')"

    printf "\033[1;33m[%d]\033[0m \033[1m%s:%s\033[0m (%s)\n" "$COUNT" "$PATH_" "$LINE" "$AUTHOR"
    echo "$BODY" | sed 's/^/    /'
    printf "    \033[2mthread-id: %s\033[0m\n" "$THREAD_ID"
    echo
done < <(jq -c '.data.repository.pullRequest.reviewThreads.nodes[]' "$CACHE")

if [[ $COUNT -eq 0 ]]; then
    echo "No unresolved review threads."
else
    echo "---"
    echo "$COUNT unresolved thread(s). Run: pr-resolve <number>  or  pr-resolve <thread-id>"
fi

# Write an index file so pr-resolve can look up by number
jq '[.data.repository.pullRequest.reviewThreads.nodes[] | select(.isResolved == false)]' "$CACHE" \
    > "/tmp/pr-threads-${PR}.json"
